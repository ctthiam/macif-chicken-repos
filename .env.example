APP_NAME="MACIF CHICKEN"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend Angular URL (CORS)
FRONTEND_URL=http://localhost:4200

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── PostgreSQL ────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=macif_chicken
DB_USERNAME=postgres
DB_PASSWORD=sis

# ─── Redis (Cache + Queues) ────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie

# ─── Mail (Mailgun) ────────────────────────────────────────
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS=noreply@macifchicken.sn
MAIL_FROM_NAME="MACIF CHICKEN"
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# ─── Sanctum ───────────────────────────────────────────────
# httpOnly cookies — NE PAS utiliser localStorage côté Angular
SANCTUM_STATEFUL_DOMAINS=localhost:4200,localhost

# ─── PayTech (Wave + Orange Money + Free Money) ────────────
PAYTECH_API_KEY=
PAYTECH_SECRET_KEY=
PAYTECH_ENV=test  # test | prod

# ─── Cloudflare R2 (Stockage fichiers) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=macif-chicken
AWS_URL=
AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── SMS (Twilio ou InfoBip) ───────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ─── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Admin par défaut (seeder) ─────────────────────────────
ADMIN_EMAIL=admin@macifchicken.sn
ADMIN_PASSWORD=Admin@2026!
ADMIN_PHONE=+221700000000

# ─── Escrow auto-liberation (heures) ──────────────────────
ESCROW_LIBERATION_HOURS=48
